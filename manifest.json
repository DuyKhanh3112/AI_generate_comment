{
  "manifest_version": 3,
  "name": "SocialAI - Intelligent Facebook Comment Generator",
  "short_name": "SocialAI",
  "version": "1.1.0",
  "description": "Tự động tạo bình luận thông minh, lịch sự và tự nhiên cho Facebook bằng công nghệ AI (Gemini/Groq).",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.facebook.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.groq.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.facebook.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}